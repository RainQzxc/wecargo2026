generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =========================
// ENUMS
// =========================

enum Role {
  SUPER_ADMIN
  ADMIN
  WAREHOUSE_STAFF
  CUSTOMER
  COURIER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum WarehouseType {
  EREEN
  ULAANBAATAR
  OTHER
}

enum ParcelOwnerStatus {
  IDENTIFIED
  UNIDENTIFIED
  CLAIM_PENDING
}

enum CargoPriority {
  REGULAR
  URGENT
}

enum ParcelStatus {
  REGISTERED
  RECEIVED_AT_EREEN
  MEASURED
  PRICED
  UNIDENTIFIED
  READY_FOR_LOADING
  LOADED
  DEPARTED_EREEN
  IN_TRANSIT
  ARRIVED_ULAANBAATAR
  SORTING
  READY_FOR_PICKUP
  DELIVERY_REQUESTED
  OUT_FOR_DELIVERY
  DELIVERED
  STORAGE_REQUESTED
  ISSUE
  CANCELLED
}

enum PaymentStatus {
  NOT_REQUIRED
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum BatchStatus {
  DRAFT
  LOADING
  LOADED
  DEPARTED
  ARRIVED_ULAANBAATAR
  CLOSED
  CANCELLED
}

enum LinkOrderStatus {
  REQUESTED
  REVIEWING
  PAYMENT_PENDING
  ORDERED
  SELLER_SHIPPED
  TRACK_CODE_ADDED
  RECEIVED_AT_EREEN
  LINKED_TO_PARCEL
  CANCELLED
  ISSUE
}

enum DeliveryStatus {
  REQUESTED
  ASSIGNED
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
  CANCELLED
}

enum StorageStatus {
  REQUESTED
  APPROVED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OwnershipClaimStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

enum BannerPlacement {
  HOME_HERO
  HOME_SECTION
  ALERT
  PRICING
  COOPERATION
}

enum LeadType {
  COOPERATION
  CONTACT
}

// =========================
// USERS / AUTH
// =========================

model User {
  id              String     @id @default(cuid())
  role            Role       @default(CUSTOMER)
  status          UserStatus @default(ACTIVE)

  name            String?
  phone           String?
  phoneNormalized String?
  email           String?
  passwordHash    String?

  lastLoginAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  customerProfile CustomerProfile?
  staffProfile    StaffProfile?
  addresses       Address[]

  // Parcel relations
  parcels               Parcel[]          @relation("CustomerParcels")
  createdParcels        Parcel[]          @relation("CreatedParcels")
  updatedParcels        Parcel[]          @relation("UpdatedParcels")

  // ParcelEvent
  createdParcelEvents   ParcelEvent[]     @relation("ParcelEventCreatedBy")

  // ParcelPhoto
  uploadedParcelPhotos  ParcelPhoto[]     @relation("ParcelPhotoUploadedBy")

  // OwnershipClaim
  ownershipClaims       OwnershipClaim[]  @relation("OwnershipClaimant")
  reviewedClaims        OwnershipClaim[]  @relation("OwnershipClaimReviewer")

  // ShipmentBatch
  createdBatches        ShipmentBatch[]   @relation("BatchCreatedBy")

  // ShipmentBatchItem
  addedBatchItems       ShipmentBatchItem[] @relation("BatchItemAddedBy")

  // TariffRule
  createdTariffRules    TariffRule[]      @relation("TariffRuleCreatedBy")

  // LinkOrder
  linkOrders            LinkOrder[]       @relation("CustomerLinkOrders")

  // DeliveryRequest
  deliveryRequests      DeliveryRequest[] @relation("CustomerDeliveryRequests")
  courierDeliveries     DeliveryRequest[] @relation("CourierDeliveries")

  // DeliveryEvent
  createdDeliveryEvents DeliveryEvent[]   @relation("DeliveryEventCreatedBy")

  // StorageRequest
  storageRequests       StorageRequest[]  @relation("CustomerStorageRequests")

  // Banner
  createdBanners        Banner[]          @relation("BannerCreatedBy")

  // Notifications / Audit
  notifications         NotificationLog[] @relation("UserNotifications")
  auditLogs             AuditLog[]        @relation("AuditLogActor")

  // Auth
  passwordResetTokens   PasswordResetToken[] @relation("UserPasswordResetTokens")

  @@unique([phoneNormalized])
  @@unique([email])
  @@index([role])
  @@index([status])
}

model CustomerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  customerCode    String?  @unique
  defaultBranchId String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  defaultBranch   Branch?  @relation("CustomerDefaultBranch", fields: [defaultBranchId], references: [id])
}

model StaffProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  employeeCode String?  @unique
  warehouseId  String?
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  warehouse    Warehouse? @relation("StaffWarehouse", fields: [warehouseId], references: [id])
  branch       Branch?    @relation("StaffBranch", fields: [branchId], references: [id])
}

model Address {
  id        String   @id @default(cuid())
  userId    String
  label     String?
  city      String?
  district  String?
  khoroo    String?
  street    String?
  detail    String
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// =========================
// LOCATIONS
// =========================

model Warehouse {
  id         String        @id @default(cuid())
  name       String
  type       WarehouseType
  phone      String?
  addressMn  String?
  addressCn  String?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  staff              StaffProfile[]    @relation("StaffWarehouse")
  originParcels      Parcel[]          @relation("OriginWarehouse")
  currentParcels     Parcel[]          @relation("CurrentWarehouse")
  destinationParcels Parcel[]          @relation("DestinationWarehouse")
  originBatches      ShipmentBatch[]   @relation("BatchOriginWarehouse")
  destinationBatches ShipmentBatch[]   @relation("BatchDestinationWarehouse")

  @@index([type])
  @@index([isActive])
}

model Branch {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  city      String?
  district  String?
  latitude  Decimal? @db.Decimal(10, 7)
  longitude Decimal? @db.Decimal(10, 7)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff            StaffProfile[]    @relation("StaffBranch")
  defaultCustomers CustomerProfile[] @relation("CustomerDefaultBranch")
  parcels          Parcel[]          @relation("DestinationBranch")
  batches          ShipmentBatch[]   @relation("BatchDestinationBranch")

  @@index([isActive])
}

// =========================
// PARCELS / CARGO
// =========================

model Parcel {
  id          String @id @default(cuid())
  publicCode  String @unique @default(cuid())

  trackCodeOriginal   String?
  trackCodeNormalized String?

  customerId              String?
  customerName            String?
  customerPhone           String?
  customerPhoneNormalized String?

  ownerStatus   ParcelOwnerStatus @default(IDENTIFIED)
  status        ParcelStatus      @default(REGISTERED)
  priority      CargoPriority     @default(REGULAR)
  paymentStatus PaymentStatus     @default(UNPAID)

  cargoType   String?
  description String?
  quantity    Int     @default(1)

  weightKg Decimal? @db.Decimal(12, 3)
  weightTon Decimal? @db.Decimal(12, 3)
  lengthCm Decimal? @db.Decimal(12, 2)
  widthCm  Decimal? @db.Decimal(12, 2)
  heightCm Decimal? @db.Decimal(12, 2)
  volumeM3 Decimal? @db.Decimal(12, 4)

  priceAmount Decimal? @db.Decimal(14, 2)
  currency    String   @default("MNT")

  originWarehouseId      String?
  currentWarehouseId     String?
  destinationWarehouseId String?
  destinationBranchId    String?

  currentLocationText String?
  storageLocation     String?
  notes               String?
  internalNotes       String?

  linkOrderId String?
  createdById String?
  updatedById String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  customer             User?      @relation("CustomerParcels", fields: [customerId], references: [id])
  createdBy            User?      @relation("CreatedParcels", fields: [createdById], references: [id])
  updatedBy            User?      @relation("UpdatedParcels", fields: [updatedById], references: [id])
  originWarehouse      Warehouse? @relation("OriginWarehouse", fields: [originWarehouseId], references: [id])
  currentWarehouse     Warehouse? @relation("CurrentWarehouse", fields: [currentWarehouseId], references: [id])
  destinationWarehouse Warehouse? @relation("DestinationWarehouse", fields: [destinationWarehouseId], references: [id])
  destinationBranch    Branch?    @relation("DestinationBranch", fields: [destinationBranchId], references: [id])
  linkOrder            LinkOrder? @relation("LinkOrderParcels", fields: [linkOrderId], references: [id])

  events          ParcelEvent[]
  photos          ParcelPhoto[]
  batchItems      ShipmentBatchItem[]
  ownershipClaims OwnershipClaim[]
  deliveryRequests DeliveryRequest[]
  storageRequests  StorageRequest[]
  notifications    NotificationLog[]   @relation("ParcelNotifications")

  @@index([trackCodeNormalized])
  @@index([customerPhoneNormalized])
  @@index([customerId])
  @@index([ownerStatus])
  @@index([status])
  @@index([priority])
  @@index([paymentStatus])
  @@index([currentWarehouseId])
  @@index([destinationBranchId])
  @@index([createdAt])
  @@index([deletedAt])
}

model ParcelEvent {
  id           String       @id @default(cuid())
  parcelId     String
  status       ParcelStatus
  messageMn    String?
  messageEn    String?
  locationText String?
  metadata     Json?
  createdById  String?
  createdAt    DateTime     @default(now())

  parcel    Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  createdBy User?  @relation("ParcelEventCreatedBy", fields: [createdById], references: [id])

  @@index([parcelId])
  @@index([status])
  @@index([createdAt])
}

model ParcelPhoto {
  id           String   @id @default(cuid())
  parcelId     String
  url          String
  fileName     String?
  mimeType     String?
  sizeBytes    Int?
  caption      String?
  uploadedById String?
  createdAt    DateTime @default(now())

  parcel     Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  uploadedBy User?  @relation("ParcelPhotoUploadedBy", fields: [uploadedById], references: [id])

  @@index([parcelId])
}

model OwnershipClaim {
  id                      String               @id @default(cuid())
  parcelId                String
  claimantUserId          String?
  claimantName            String?
  claimantPhone           String?
  claimantPhoneNormalized String?
  submittedTrackCode      String?
  message                 String?
  status                  OwnershipClaimStatus @default(PENDING)
  reviewedById            String?
  reviewedAt              DateTime?
  reviewNote              String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  parcel       Parcel @relation(fields: [parcelId], references: [id], onDelete: Cascade)
  claimantUser User?  @relation("OwnershipClaimant", fields: [claimantUserId], references: [id])
  reviewedBy   User?  @relation("OwnershipClaimReviewer", fields: [reviewedById], references: [id])

  @@index([parcelId])
  @@index([claimantPhoneNormalized])
  @@index([status])
}

// =========================
// SHIPMENT BATCHES
// =========================

model ShipmentBatch {
  id                    String      @id @default(cuid())
  batchNo               String      @unique
  status                BatchStatus @default(DRAFT)
  originWarehouseId     String
  destinationWarehouseId String?
  destinationBranchId   String?
  vehiclePlate          String?
  driverName            String?
  driverPhone           String?
  notes                 String?
  loadedAt              DateTime?
  departedAt            DateTime?
  arrivedAt             DateTime?
  closedAt              DateTime?
  createdById           String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  originWarehouse      Warehouse  @relation("BatchOriginWarehouse", fields: [originWarehouseId], references: [id])
  destinationWarehouse Warehouse? @relation("BatchDestinationWarehouse", fields: [destinationWarehouseId], references: [id])
  destinationBranch    Branch?    @relation("BatchDestinationBranch", fields: [destinationBranchId], references: [id])
  createdBy            User?      @relation("BatchCreatedBy", fields: [createdById], references: [id])

  items ShipmentBatchItem[]

  @@index([status])
  @@index([originWarehouseId])
  @@index([destinationWarehouseId])
  @@index([createdAt])
}

model ShipmentBatchItem {
  id        String   @id @default(cuid())
  batchId   String
  parcelId  String
  addedById String?
  addedAt   DateTime @default(now())

  batch   ShipmentBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  parcel  Parcel        @relation(fields: [parcelId], references: [id])
  addedBy User?         @relation("BatchItemAddedBy", fields: [addedById], references: [id])

  @@unique([batchId, parcelId])
  @@index([batchId])
  @@index([parcelId])
}

// =========================
// TARIFFS / PRICING
// =========================

model TariffRule {
  id            String         @id @default(cuid())
  name          String
  description   String?
  routeCode     String?
  cargoType     String?
  priority      CargoPriority?
  unit          String
  priceAmount   Decimal        @db.Decimal(14, 2)
  currency      String         @default("CNY")
  minFeeAmount  Decimal?       @db.Decimal(14, 2)
  config        Json?
  isActive      Boolean        @default(true)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdById   String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  createdBy User? @relation("TariffRuleCreatedBy", fields: [createdById], references: [id])

  @@index([routeCode])
  @@index([cargoType])
  @@index([priority])
  @@index([isActive])
}

// =========================
// LINK ORDERS
// =========================

model LinkOrder {
  id                        String          @id @default(cuid())
  customerId                String?
  customerName              String?
  customerPhone             String?
  customerPhoneNormalized   String?
  productUrl                String
  quantity                  Int             @default(1)
  color                     String?
  size                      String?
  notes                     String?
  priority                  CargoPriority   @default(REGULAR)
  status                    LinkOrderStatus @default(REQUESTED)
  storeName                 String?
  storeOrderNo              String?
  sellerTrackCodeOriginal   String?
  sellerTrackCodeNormalized String?
  productPriceAmount        Decimal?        @db.Decimal(14, 2)
  domesticShippingFee       Decimal?        @db.Decimal(14, 2)
  serviceFeeAmount          Decimal?        @db.Decimal(14, 2)
  totalAmount               Decimal?        @db.Decimal(14, 2)
  currency                  String          @default("CNY")
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt

  customer User?    @relation("CustomerLinkOrders", fields: [customerId], references: [id])
  parcels  Parcel[] @relation("LinkOrderParcels")

  @@index([customerId])
  @@index([customerPhoneNormalized])
  @@index([sellerTrackCodeNormalized])
  @@index([status])
  @@index([createdAt])
}

// =========================
// DELIVERY / STORAGE
// =========================

model DeliveryRequest {
  id                       String         @id @default(cuid())
  parcelId                 String
  customerId               String?
  courierId                String?
  status                   DeliveryStatus @default(REQUESTED)
  recipientName            String?
  recipientPhone           String?
  recipientPhoneNormalized String?
  city                     String?
  district                 String?
  addressDetail            String
  preferredTime            String?
  notes                    String?
  deliveryFeeAmount        Decimal?       @db.Decimal(14, 2)
  currency                 String         @default("MNT")
  assignedAt               DateTime?
  deliveredAt              DateTime?
  failedReason             String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  parcel   Parcel @relation(fields: [parcelId], references: [id])
  customer User?  @relation("CustomerDeliveryRequests", fields: [customerId], references: [id])
  courier  User?  @relation("CourierDeliveries", fields: [courierId], references: [id])

  events DeliveryEvent[]

  @@index([parcelId])
  @@index([customerId])
  @@index([courierId])
  @@index([status])
  @@index([createdAt])
}

model DeliveryEvent {
  id          String         @id @default(cuid())
  deliveryId  String
  status      DeliveryStatus
  note        String?
  createdById String?
  createdAt   DateTime       @default(now())

  delivery  DeliveryRequest @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  createdBy User?           @relation("DeliveryEventCreatedBy", fields: [createdById], references: [id])

  @@index([deliveryId])
  @@index([createdAt])
}

model StorageRequest {
  id        String        @id @default(cuid())
  parcelId  String
  userId    String?
  status    StorageStatus @default(REQUESTED)
  days      Int?
  startAt   DateTime?
  endAt     DateTime?
  notes     String?
  feeAmount Decimal?      @db.Decimal(14, 2)
  currency  String        @default("MNT")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  parcel Parcel @relation(fields: [parcelId], references: [id])
  user   User?  @relation("CustomerStorageRequests", fields: [userId], references: [id])

  @@index([parcelId])
  @@index([userId])
  @@index([status])
}

// =========================
// CONTENT / LANDING
// =========================

model Banner {
  id          String          @id @default(cuid())
  placement   BannerPlacement
  title       String
  subtitle    String?
  imageUrl    String?
  href        String?
  ctaLabel    String?
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  createdById String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  createdBy User? @relation("BannerCreatedBy", fields: [createdById], references: [id])

  @@index([placement])
  @@index([isActive])
  @@index([sortOrder])
}

model Faq {
  id         String   @id @default(cuid())
  questionMn String
  answerMn   String
  questionEn String?
  answerEn   String?
  category   String?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Testimonial {
  id         String   @id @default(cuid())
  authorName String
  authorRole String?
  avatarUrl  String?
  quoteMn    String
  quoteEn    String?
  rating     Int?
  sortOrder  Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model Lead {
  id                 String   @id @default(cuid())
  type               LeadType
  name               String?
  phone              String?
  phoneNormalized    String?
  email              String?
  companyName        String?
  message            String?
  monthlyCargoVolume String?
  cargoType          String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([type])
  @@index([phoneNormalized])
  @@index([createdAt])
}

// =========================
// NOTIFICATIONS / AUDIT
// =========================

model NotificationLog {
  id           String              @id @default(cuid())
  channel      NotificationChannel
  status       NotificationStatus  @default(PENDING)
  recipient    String
  message      String
  userId       String?
  parcelId     String?
  provider     String?
  providerRef  String?
  errorMessage String?
  metadata     Json?
  sentAt       DateTime?
  createdAt    DateTime            @default(now())

  user   User?   @relation("UserNotifications", fields: [userId], references: [id])
  parcel Parcel? @relation("ParcelNotifications", fields: [parcelId], references: [id])

  @@index([channel])
  @@index([status])
  @@index([recipient])
  @@index([parcelId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  beforeJson Json?
  afterJson  Json?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation("AuditLogActor", fields: [actorId], references: [id])

  @@index([actorId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

// =========================
// AUTH
// =========================

// Single-use, hashed password-reset tokens. The raw token is emailed to the
// user; only its SHA-256 hash is stored. Look up by tokenHash, check expiresAt
// and usedAt, then set usedAt to consume.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation("UserPasswordResetTokens", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}
