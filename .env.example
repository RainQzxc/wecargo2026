# Copy to `.env` and fill in. Never commit real secrets — `.env*` is gitignored.

# --- Database (required) ---------------------------------------------------
# Postgres connection string used by the Prisma driver adapter at runtime and
# by the Prisma CLI for migrations/seed (read via prisma.config.ts).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wecargo?schema=public"

# --- Session signing (required in production) ------------------------------
# HMAC key for the signed session cookie (src/features/auth/session.ts).
# In production the app THROWS if this is unset. Generate a strong value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# NEXTAUTH_SECRET is accepted as a fallback.
SESSION_SECRET=""
